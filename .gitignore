# ============================================================
# KeyMart Global — Root .gitignore (Monorepo)
# ============================================================

# ── Secrets — NEVER commit these ───────────────────────────
backend/.env
backend/credentials.json
backend/*.json
frontend/.env

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
*.log

# ── Node / Frontend ─────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
